# wagent 環境變數範本 — 複製成 .env 後填入

# 選擇 LLM 後端：anthropic | openai_compat
WAGENT_LLM_BACKEND=anthropic

# Anthropic Claude
ANTHROPIC_API_KEY=
WAGENT_ANTHROPIC_MODEL=claude-opus-4-8

# OpenAI-compatible 端點（自架 / OpenAI / 其他相容服務）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
WAGENT_OPENAI_MODEL=gpt-4o

# 瀏覽器 agent 行為
WAGENT_MAX_STEPS=40
# 每步連續失敗容忍次數（吸收 LLM 偶發產出格式錯誤）；調高更耐錯
WAGENT_MAX_FAILURES=5
WAGENT_CAPTCHA_AI_ATTEMPTS=2
WAGENT_HEADLESS=false

# 接棒策略：human_first（一遇驗證就交人）/ ai_then_human（AI先試，卡住才交人，預設）/ ai_only
WAGENT_HANDOFF_POLICY=ai_then_human

# 合規與安全
WAGENT_RESPECT_ROBOTS=true                 # 尊重目標站 robots.txt（不允許則拒跑）
WAGENT_COMPLIANCE_DENYLIST=                # 拒絕網域，逗號分隔（含子網域），如 example.com,foo.org
WAGENT_MIN_DOMAIN_INTERVAL_SEC=2.0         # 同網域任務最小間隔（禮貌節流）
WAGENT_USER_AGENT=wagent-bot               # robots 比對用的 user-agent
